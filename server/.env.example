# Copy to .env and fill in — never commit the real .env file.

# Google Sheet spreadsheet ID (Code.gs SS_ID: 16ryjqdieYbZAaG9phRMVInz_Yt6bP8KtWmEYXBcZRH0)
SHEET_ID=

# Path to a service-account JSON key with read access to the sheet above.
# Create the service account in the GCP project, then share the Google Sheet
# (Share button) with the service account's email as Viewer.
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Cloud SQL for PostgreSQL connection string.
# Local/Cloud SQL Auth Proxy example: postgres://USER:PASSWORD@127.0.0.1:5432/lhb_hr
DATABASE_URL=
